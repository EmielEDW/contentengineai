# ─── Supabase ────────────────────────────────────────────────────────────────
# From your Supabase project settings (or `supabase start` for local).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the client. Used by Inngest jobs + admin tasks.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Inngest ─────────────────────────────────────────────────────────────────
# Leave empty for local `inngest dev`. Set these in production (Inngest Cloud).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Secret encryption ───────────────────────────────────────────────────────
# 32-byte base64 key used to encrypt BYO provider keys at the app layer when
# Supabase Vault is not used. Generate with: openssl rand -base64 32
APP_SECRET_ENCRYPTION_KEY=

# ─── Platform provider keys (defaults / fallback) ────────────────────────────
# These power the "platform key" path. Per-org BYO keys override them (see api_keys).
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
FAL_KEY=
ELEVENLABS_API_KEY=

# ─── YouTube Data API (Phase 6, behind a flag, post compliance audit) ────────
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=

# ─── Transactional email (Phase 5 notifications) ─────────────────────────────
RESEND_API_KEY=

# ─── Feature flags ───────────────────────────────────────────────────────────
# In-app YouTube upload/schedule stays OFF until the Google Cloud project passes
# the YouTube API compliance audit. Until then, delivery = export .zip + manual upload.
FEATURE_YOUTUBE_UPLOAD=false
